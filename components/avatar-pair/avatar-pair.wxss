/* components/avatar-pair/avatar-pair.wxss */
.avatar-pair {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
}

.avatar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  animation: float 3s ease-in-out infinite;
}

.avatar-item:first-child {
  animation-delay: 0s;
}

.avatar-item:last-child {
  animation-delay: 0.5s;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.8);
}

.avatar-name {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.heart-connector {
  display: flex;
  align-items: center;
  justify-content: center;
}

.heart-icon {
  font-size: 36rpx;
  animation: pulseHeart 1.5s ease-in-out infinite;
}

.avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  border: 4rpx dashed rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(255,255,255,0.6);
}
