<!-- pages/diary/diary.wxml -->
<view class="diary-container">
  <!-- 页面标题 -->
  <view class="diary-header">
    <text class="diary-title">美食日记 📖</text>
    <view class="view-toggle">
      <view
        class="toggle-btn {{viewMode === 'week' ? 'active' : ''}}"
        bindtap="toggleViewMode"
      >
        <text class="toggle-icon">📅</text>
      </view>
      <view
        class="toggle-btn {{viewMode === 'month' ? 'active' : ''}}"
        bindtap="toggleViewMode"
      >
        <text class="toggle-icon">📆</text>
      </view>
    </view>
  </view>

  <!-- 日历卡片 -->
  <view class="calendar-card">
    <!-- 月份导航 -->
    <view class="calendar-nav">
      <view class="nav-btn" bindtap="prevPeriod">
        <text class="nav-icon">‹</text>
      </view>
      <text class="calendar-month" wx:if="{{viewMode === 'week'}}">
        {{currentYear}}年 第{{weekNumber}}周
      </text>
      <text class="calendar-month" wx:else>
        {{currentYear}}年 {{months[currentMonth]}}
      </text>
      <view class="nav-btn" bindtap="nextPeriod">
        <text class="nav-icon">›</text>
      </view>
    </view>

    <!-- 星期标题 -->
    <view class="weekdays">
      <text class="weekday" wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 日期网格 -->
    <view class="calendar-grid {{viewMode === 'week' ? 'week-view' : ''}}">
      <view
        class="calendar-day {{item.empty ? 'empty' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}} {{item.hasEntry ? 'has-entry' : ''}}"
        wx:for="{{calendarDays}}"
        wx:key="dateKey"
        data-date="{{item.dateKey}}"
        bindtap="selectDate"
      >
        <text wx:if="{{!item.empty}}">{{item.day}}</text>
      </view>
    </view>
  </view>

  <!-- 选中日期详情 -->
  <view class="entry-detail" wx:if="{{selectedEntry}}">
    <!-- 头部信息 -->
    <view class="entry-header">
      <view class="chef-avatar">
        {{selectedEntry.chef === '小明' ? '👨‍🍳' : '👩‍🍳'}}
      </view>
      <view class="entry-info">
        <text class="chef-name">{{selectedEntry.chef}}</text>
        <text class="entry-date">{{selectedDate}}</text>
      </view>
      <view class="entry-rating">
        <text class="rating-heart" wx:for="{{selectedEntry.rating}}" wx:key="*this">❤️</text>
      </view>
    </view>

    <!-- 菜品图片 -->
    <view class="dish-images" wx:if="{{selectedEntry.images}}">
      <scroll-view class="images-scroll" scroll-x>
        <view
          class="dish-image-box"
          wx:for="{{expandedImages ? selectedEntry.images : selectedEntry.images.slice(0, 4)}}"
          wx:key="*this"
        >
          <text>{{item}}</text>
        </view>
        <view
          class="more-images-btn"
          wx:if="{{!expandedImages && selectedEntry.images.length > 4}}"
          bindtap="expandImages"
        >
          +{{selectedEntry.images.length - 4}}
        </view>
      </scroll-view>
    </view>

    <!-- 菜品标签 -->
    <view class="dish-tags">
      <text class="dish-tag" wx:for="{{selectedEntry.dishes}}" wx:key="*this">
        {{item}}
      </text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-entry" wx:else>
    选择日期查看美食回忆 💭
  </view>
</view>
