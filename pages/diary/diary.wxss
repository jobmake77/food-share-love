/* pages/diary/diary.wxss */
.diary-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 40rpx 40rpx 160rpx;
}

/* ========== 页面标题 ========== */
.diary-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.diary-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.view-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-card);
  border-radius: var(--radius-sm);
  padding: 4rpx;
}

.toggle-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.toggle-btn.active {
  background: var(--color-primary);
}

.toggle-icon {
  font-size: 28rpx;
}

/* ========== 日历卡片 ========== */
.calendar-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 40rpx;
  animation: fadeInUp 0.6s ease-out forwards;
}

.calendar-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.nav-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.nav-btn:active {
  background: var(--color-secondary);
}

.nav-icon {
  font-size: 32rpx;
  color: var(--color-text-hint);
}

.calendar-month {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 星期标题 */
.weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.weekday {
  font-size: 18rpx;
  color: var(--color-text-hint);
  font-weight: 600;
  padding: 8rpx 0;
}

/* 日期网格 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-day {
  position: relative;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  transition: all 0.3s ease;
}

.calendar-day.empty {
  visibility: hidden;
}

.calendar-day.today {
  background: var(--color-secondary);
  color: var(--color-text-primary);
}

.calendar-day.selected {
  background: var(--gradient-warm);
  color: #fff;
  box-shadow: var(--shadow-warm);
  transform: scale(1.1);
}

.calendar-day.has-entry::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--color-accent);
}

.calendar-day.selected.has-entry::after {
  display: none;
}

.calendar-day:active {
  background: var(--color-secondary);
}

/* ========== 选中日期详情 ========== */
.entry-detail {
  background: var(--gradient-soft);
  border-radius: var(--radius-lg);
  padding: 40rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 40rpx;
  animation: fadeInUp 0.6s ease-out 0.1s forwards;
  opacity: 0;
}

.entry-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.chef-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(242, 125, 94, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.entry-info {
  flex: 1;
}

.chef-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.entry-date {
  font-size: 18rpx;
  color: var(--color-text-hint);
}

.entry-rating {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-heart {
  font-size: 20rpx;
}

/* 菜品图片 */
.dish-images {
  margin-bottom: 24rpx;
}

.images-scroll {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.images-scroll::-webkit-scrollbar {
  display: none;
}

.dish-image-box {
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-md);
  background: var(--color-card);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.more-images-btn {
  flex-shrink: 0;
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-md);
  background: var(--color-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--color-text-hint);
  font-weight: 600;
}

/* 菜品标签 */
.dish-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.dish-tag {
  padding: 12rpx 24rpx;
  background: var(--color-card);
  border-radius: 48rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  box-shadow: var(--shadow-card);
}

/* 空状态 */
.empty-entry {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-hint);
  font-size: 28rpx;
}
