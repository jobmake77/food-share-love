/* pages/diary/diary.wxss */
.diary-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, var(--color-bg) 300rpx);
}

/* ========== 日历头部 ========== */
.calendar-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  padding: 48rpx 32rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.cal-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cal-nav {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  backdrop-filter: blur(10rpx);
}

.nav-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 700;
}

.cal-mode-toggle {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 24rpx;
  backdrop-filter: blur(10rpx);
}

.toggle-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* ========== 日历主体 ========== */
.calendar-body {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.1);
  margin-top: -16rpx;
}

.weekday-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  padding: 0 0 16rpx;
}

.weekday {
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
  padding: 8rpx 0;
}

.dates-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.date-cell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s;
}

.date-num {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}

.empty-cell .date-num {
  color: transparent;
}

.today {
  background: rgba(255, 107, 107, 0.1);
}

.today .date-num {
  color: var(--color-primary);
  font-weight: 700;
}

.selected {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.selected .date-num {
  color: #fff;
  font-weight: 700;
}

.order-indicator {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: var(--color-secondary);
  position: absolute;
  bottom: 12rpx;
}

.selected .order-indicator {
  background: rgba(255, 255, 255, 0.9);
}

/* ========== 日记列表 ========== */
.day-orders {
  padding: 32rpx 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
}

.section-count {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ========== 日记卡片 ========== */
.diary-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.diary-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 24rpx 20rpx;
}

.diary-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-bg);
  flex-shrink: 0;
}

.diary-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.diary-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.diary-time {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ========== 图片展示（4.5个效果） ========== */
.dish-images-container {
  position: relative;
  margin-bottom: 20rpx;
}

.dish-images-scroll {
  width: 100%;
  overflow: hidden;
}

.dish-images-scroll.expanded {
  overflow-x: scroll;
}

.dish-images-wrapper {
  display: flex;
  gap: 8rpx;
  padding: 0 24rpx;
}

.dish-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: var(--color-bg);
  object-fit: cover;
  flex-shrink: 0;
}

/* 未展开时的遮罩效果 */
.dish-images-scroll:not(.expanded) .dish-images-wrapper {
  position: relative;
}

.dish-images-scroll:not(.expanded) .dish-images-wrapper::after {
  content: '';
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100rpx;
  background: linear-gradient(to right, transparent, #fff);
  pointer-events: none;
}

/* 展开按钮 */
.expand-btn {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.expand-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 700;
}

/* ========== 备注 ========== */
.diary-note {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
  padding: 0 24rpx 24rpx;
  word-break: break-all;
}
