<!-- pages/home/home.wxml -->
<view class="home-container">
  <!-- 授权引导（首次进入时显示） -->
  <view class="auth-guide" wx:if="{{needAuth && loaded}}">
    <view class="auth-content">
      <text class="auth-emoji">👋</text>
      <text class="auth-title">欢迎来到食物分享爱</text>
      <text class="auth-desc">获取你的微信昵称和头像，开启美食之旅</text>
      <button
        class="btn-primary btn-large"
        bindtap="handleAuth"
        disabled="{{authLoading}}"
        loading="{{authLoading}}"
      >
        {{authLoading ? '登录中...' : '微信授权登录'}}
      </button>
      <text class="auth-skip" bindtap="skipAuth">暂时跳过</text>
      <text class="auth-tip">登录后即可获取你的专属识别码</text>
    </view>
  </view>

  <!-- 主界面（授权后显示） -->
  <view wx:else class="main-content">
    <!-- Hero 区域 -->
    <view class="hero-section">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <!-- 情侣头像对 -->
        <view class="couple-avatars">
          <view class="avatar-wrapper">
            <view class="avatar-circle">
              <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" class="avatar-img" mode="aspectFill" />
              <text wx:else class="avatar-emoji">👨‍🍳</text>
            </view>
            <view class="avatar-name-tag">{{userInfo.nickname || '小明'}}</view>
          </view>
          <view class="heart-icon">❤️</view>
          <view class="avatar-wrapper">
            <view class="avatar-circle">
              <image wx:if="{{partnerInfo.avatar}}" src="{{partnerInfo.avatar}}" class="avatar-img" mode="aspectFill" />
              <text wx:else class="avatar-emoji">👩‍🍳</text>
            </view>
            <view class="avatar-name-tag">{{partnerInfo.nickname || '小美'}}</view>
          </view>
        </view>

        <!-- 动态问候 -->
        <view class="greeting-text">{{greeting}}</view>
      </view>
    </view>

    <!-- 未绑定提示 -->
    <view class="unbind-alert" wx:if="{{!userInfo.partnerId && loaded}}">
      <view class="alert-icon">⚠️</view>
      <view class="alert-content">
        <view class="alert-title">还没有绑定伙伴</view>
        <view class="alert-desc">去「我的」页面绑定你的另一半吧～</view>
      </view>
      <view class="alert-btn" bindtap="goProfile">去绑定</view>
    </view>

    <!-- 双卡片操作区 -->
    <view class="action-cards">
      <view class="action-card" bindtap="goMenu">
        <view class="card-icon-wrapper primary">
          <text class="card-icon">🍽️</text>
        </view>
        <view class="card-title">我要点单</view>
        <view class="card-desc">挑选今天想吃的菜 🍜</view>
        <view class="card-bg-emoji">🍜</view>
      </view>

      <view class="action-card" bindtap="goGame">
        <view class="card-icon-wrapper accent">
          <text class="card-icon">🎮</text>
        </view>
        <view class="card-title">游戏</view>
        <view class="card-desc">玩个小游戏，决定今天谁掌勺 🎮</view>
        <view class="card-bg-emoji">🎮</view>
      </view>
    </view>

    <!-- 今日推荐 -->
    <view class="recommend-section">
      <view class="section-header">
        <view class="section-title">今日推荐</view>
        <view class="section-more" bindtap="goMenu">查看更多 →</view>
      </view>
      <view class="recommend-list">
        <view class="recommend-item" wx:for="{{recommendDishes}}" wx:key="id">
          <view class="dish-emoji">{{item.emoji}}</view>
          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-tags">
              <view class="dish-tag">{{item.tag}}</view>
              <view class="dish-time">⏱ {{item.time}}</view>
            </view>
          </view>
          <view class="dish-add-btn" bindtap="addDish" data-id="{{item.id}}">+</view>
        </view>
      </view>
    </view>

    <!-- 爱情统计 -->
    <view class="love-stats">
      <view class="stats-header">
        <text class="stats-heart">❤️</text>
        <text class="stats-title">我们的美食故事</text>
      </view>
      <view class="stats-grid">
        <view class="stat-item">
          <view class="stat-num primary">28</view>
          <view class="stat-label">共做美食</view>
        </view>
        <view class="stat-item">
          <view class="stat-num accent">15</view>
          <view class="stat-label">拿手好菜</view>
        </view>
        <view class="stat-item">
          <view class="stat-num secondary">42</view>
          <view class="stat-label">在一起(天)</view>
        </view>
      </view>
    </view>
  </view>
</view>
