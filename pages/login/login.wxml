<view class="login-container">

  <view class="top-bar animate-fade-in-up">
    <text class="heart-icon animate-pulse-heart">♥</text>
    <text class="brand-text">FOOD SHARE LOVE</text>
    <text class="heart-icon animate-pulse-heart delay-200">♥</text>
  </view>

  <view class="main-area">
    <image
      class="illustration animate-float"
      src="/assets/login-illustration.png"
      mode="aspectFit"
    />

    <view class="title-section">
      <text class="main-title">今天想吃什么？</text>
      <text class="sub-title">记录每一次爱的味道 💕</text>
    </view>

    <view class="login-step-card" wx:if="{{phoneRequiredNotice}}">
      <text class="login-step-title">{{loginStep === 'phone' ? '确认手机号' : '微信授权'}}</text>
      <text class="login-step-desc">{{phoneRequiredNotice}}</text>
    </view>

    <view class="privacy-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="check-mark">✓</text>
      </view>
      <view class="privacy-text">
        <text>我已阅读并同意</text>
        <text class="privacy-link" catchtap="showPrivacy"> 《用户服务协议》 </text>
        <text>及</text>
        <text class="privacy-link" catchtap="showPrivacy"> 《隐私政策》</text>
      </view>
    </view>

    <button
      wx:if="{{loginStep === 'profile'}}"
      class="btn-wechat {{!agreed ? 'btn-disabled' : ''}}"
      bindtap="handleLogin"
      disabled="{{loading || !agreed}}"
      loading="{{loading}}"
    >
      <image wx:if="{{!loading}}" class="wechat-icon" src="/assets/icons/wechat.png" mode="aspectFit" />
      <text class="btn-text">{{loading ? '处理中...' : '微信授权头像昵称'}}</text>
    </button>

    <button
      wx:if="{{loginStep === 'phone'}}"
      class="btn-phone {{!agreed ? 'btn-disabled' : ''}}"
      open-type="getPhoneNumber"
      bindgetphonenumber="handleGetPhoneNumber"
      disabled="{{loading || !agreed}}"
      loading="{{loading}}"
    >
      <text wx:if="{{!loading}}" class="phone-icon">📱</text>
      <text class="btn-text">{{loading ? '登录中...' : '点击授权当前微信手机号'}}</text>
    </button>
  </view>

  <view class="footer">
    <text class="footer-text">用爱调味 · 用心做饭</text>
  </view>

</view>
