<view class="login-container">

  <view class="top-bar animate-fade-in-up">
    <text class="heart-icon animate-pulse-heart">♥</text>
    <text class="brand-text">FOOD SHARE LOVE</text>
    <text class="heart-icon animate-pulse-heart delay-200">♥</text>
  </view>

  <view class="main-area">
    <image
      class="illustration animate-float"
      src="/assets/login-illustration.png"
      mode="aspectFit"
    />

    <view class="title-section">
      <text class="main-title">今天想吃什么？</text>
      <text class="sub-title">记录每一次爱的味道 💕</text>
    </view>

    <view class="privacy-row" bindtap="toggleAgree">
      <view class="checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="check-mark">✓</text>
      </view>
      <view class="privacy-text">
        <text>我已阅读并同意</text>
        <text class="privacy-link" catchtap="showPrivacy"> 《用户服务协议》 </text>
        <text>及</text>
        <text class="privacy-link" catchtap="showPrivacy"> 《隐私政策》</text>
      </view>
    </view>

    <button
      class="btn-enter {{!agreed ? 'btn-disabled' : ''}}"
      bindtap="enterMiniProgram"
      disabled="{{loading || !agreed}}"
      loading="{{loading}}"
    >
      <text class="btn-text">{{loading ? '进入中...' : '微信登录'}}</text>
    </button>
  </view>

  <view class="footer">
    <text class="footer-text">用爱调味 · 用心做饭</text>
  </view>

</view>
