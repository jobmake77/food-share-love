/* pages/login/login.wxss */

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(180deg, var(--color-secondary) 0%, var(--color-bg) 40%, var(--color-bg) 100%);
  padding: 40rpx 48rpx 48rpx;
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 24rpx;
}

.heart-icon {
  font-size: 28rpx;
  color: var(--color-accent);
}

.brand-text {
  font-size: 20rpx;
  color: var(--color-text-hint);
  letter-spacing: 6rpx;
  font-weight: 500;
}

.main-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 600rpx;
}

.illustration {
  width: 480rpx;
  height: 360rpx;
  margin-bottom: 48rpx;
  filter: drop-shadow(0 8rpx 32rpx rgba(242, 125, 94, 0.15));
}

.title-section {
  text-align: center;
  margin-bottom: 64rpx;
}

.main-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.sub-title {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

.btn-enter {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-radius: var(--radius-btn);
  background: var(--gradient-warm);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: var(--shadow-warm);
  transition: all 0.2s ease;
  margin-bottom: 32rpx;
}

.btn-enter::after {
  border: none;
}

.btn-enter:active {
  transform: scale(0.97);
}

.btn-enter[disabled] {
  opacity: 0.65;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.privacy-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 32rpx;
  width: 100%;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--color-text-hint);
  border-radius: 8rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  transition: all 0.15s ease;
}

.checkbox.checked {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.check-mark {
  font-size: 22rpx;
  color: #fff;
  line-height: 1;
}

.privacy-text {
  font-size: 22rpx;
  color: var(--color-text-hint);
  line-height: 1.7;
  flex: 1;
}

.privacy-link {
  color: var(--color-primary);
}

.btn-disabled {
  opacity: 0.45;
}

.footer {
  padding-bottom: 16rpx;
}

.footer-text {
  font-size: 20rpx;
  color: var(--color-text-hint);
  opacity: 0.5;
}
