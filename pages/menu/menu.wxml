<!-- pages/menu/menu.wxml -->
<view class="menu-container">
  <!-- 顶部信息栏 -->
  <view class="menu-header">
    <view class="header-content">
      <text class="header-title">菜单</text>
      <view class="chef-info">
        <text class="chef-icon">👨‍🍳</text>
        <text class="chef-text">今天由 <text class="chef-name">{{chefName}}</text> 掌勺</text>
      </view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索菜品..."
        value="{{searchQuery}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- 双栏布局 -->
  <view class="menu-body">
    <!-- 左侧分类栏 -->
    <scroll-view class="category-sidebar" scroll-y>
      <view
        class="category-btn {{activeCategory === item._id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="_id"
        data-category-id="{{item._id}}"
        bindtap="switchCategory"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-name">{{item.name}}</text>
      </view>

      <!-- 空状态 -->
      <view class="empty-category" wx:if="{{categories.length === 0}}">
        <text class="empty-text">暂无分类</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view class="dish-list" scroll-y>
      <view
        class="dish-card"
        wx:for="{{filteredDishes}}"
        wx:key="_id"
        style="animation-delay: {{index * 0.05}}s"
      >
        <text class="dish-emoji">{{item.emoji || '🍽️'}}</text>

        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.desc || ''}}</text>
        </view>

        <!-- 数量控制 -->
        <view class="dish-controls">
          <view
            class="control-minus"
            wx:if="{{cart[item._id]}}"
            data-id="{{item._id}}"
            data-delta="-1"
            bindtap="updateCart"
          >
            <text class="control-icon">−</text>
          </view>
          <text class="control-num" wx:if="{{cart[item._id]}}">{{cart[item._id]}}</text>
          <view
            class="control-plus"
            data-id="{{item._id}}"
            data-delta="1"
            bindtap="updateCart"
          >
            <text class="control-icon">+</text>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredDishes.length === 0}}">
        <text class="empty-emoji">🍽️</text>
        <text class="empty-text">暂无菜品</text>
      </view>
    </scroll-view>
  </view>

  <!-- 购物车浮动按钮 -->
  <view class="cart-fab" bindtap="goCart" wx:if="{{totalCount > 0}}">
    <text class="cart-icon">🛒</text>
    <view class="cart-badge">{{totalCount}}</view>
  </view>
</view>
