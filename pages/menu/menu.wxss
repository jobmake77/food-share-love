/* pages/menu/menu.wxss */
.menu-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
}

/* ========== 顶部信息栏 ========== */
.menu-header {
  padding: 40rpx 40rpx 24rpx;
  background: var(--color-bg);
}

.header-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.chef-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.chef-icon {
  font-size: 28rpx;
}

.chef-text {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.chef-name {
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ========== 搜索框 ========== */
.search-section {
  padding: 0 40rpx 32rpx;
}

.search-box {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  border: 2rpx solid var(--color-border);
  padding: 0 32rpx;
  height: 80rpx;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 6rpx rgba(242, 125, 94, 0.1);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  height: 100%;
}

/* ========== 双栏布局 ========== */
.menu-body {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding: 0 16rpx;
}

/* 左侧分类栏 */
.category-sidebar {
  width: 160rpx;
  flex-shrink: 0;
  padding-right: 8rpx;
}

.category-btn {
  width: 100%;
  padding: 24rpx 16rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-hint);
  background: var(--color-card);
  border-radius: var(--radius-xl);
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.category-btn.active {
  background: var(--gradient-warm);
  color: #fff;
  font-weight: 700;
  box-shadow: var(--shadow-warm);
  transform: scale(1.02);
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  padding: 0 8rpx 0 16rpx;
}

.dish-card {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  animation: fadeInUp 0.6s ease-out forwards;
  opacity: 0;
  transition: all 0.3s ease;
}

.dish-card:active {
  transform: scale(0.98);
}

.dish-emoji {
  font-size: 80rpx;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.dish-desc {
  font-size: 20rpx;
  color: var(--color-text-hint);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 数量控制 */
.dish-controls {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.control-minus,
.control-plus {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.control-minus {
  background: var(--color-secondary);
}

.control-minus:active {
  transform: scale(0.9);
}

.control-plus {
  background: var(--gradient-warm);
  box-shadow: var(--shadow-warm);
}

.control-plus:active {
  transform: scale(0.9);
}

.control-icon {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.control-plus .control-icon {
  color: #fff;
}

.control-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  min-width: 40rpx;
  text-align: center;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
}

/* ========== 购物车浮动按钮 ========== */
.cart-fab {
  position: fixed;
  bottom: 160rpx;
  right: 40rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--gradient-warm);
  box-shadow: var(--shadow-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeInUp 0.6s ease-out forwards;
  transition: all 0.3s ease;
}

.cart-fab:active {
  transform: scale(1.1);
}

.cart-icon {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 8rpx;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
