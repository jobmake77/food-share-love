<!-- pages/profile/profile.wxml -->
<view class="profile-container">
  <!-- 个人资料卡片 -->
  <view class="profile-card">
    <view class="profile-header">
      <view class="profile-avatar">{{myAvatar}}</view>
      <view class="profile-info">
        <text class="profile-name">{{myName}}</text>
        <text class="profile-status">
          {{isBound ? '已绑定 · 在一起第' + daysCount + '天 💕' : '未绑定伙伴'}}
        </text>
      </view>
    </view>

    <!-- 识别码 -->
    <view class="id-code-box">
      <text class="id-label">识别码</text>
      <text class="id-value">{{myCode}}</text>
      <view class="copy-btn" bindtap="copyCode">
        <text class="copy-icon">{{copied ? '✓' : '📋'}}</text>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-grid">
      <view class="stat-item" wx:for="{{stats}}" wx:key="label">
        <text class="stat-num">{{item.num}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 伙伴绑定卡片 -->
  <view class="partner-card">
    <view class="card-header">
      <text class="card-icon">🔗</text>
      <text class="card-title">伙伴绑定</text>
    </view>

    <!-- 已绑定状态 -->
    <view class="partner-info" wx:if="{{isBound}}">
      <view class="partner-avatar">{{partnerAvatar}}</view>
      <view class="partner-details">
        <text class="partner-name">{{partnerName}}</text>
        <text class="partner-code">{{partnerCode}}</text>
      </view>
      <view class="unbind-btn" bindtap="unbindPartner">
        <text>解绑</text>
      </view>
    </view>

    <!-- 未绑定状态 -->
    <view class="bind-btn" wx:else bindtap="bindPartner">
      <text class="card-icon">👥</text>
      <text>绑定伙伴</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-card">
    <view
      class="setting-item"
      wx:for="{{settingsItems}}"
      wx:key="label"
      data-label="{{item.label}}"
      bindtap="handleSettingTap"
    >
      <view class="setting-icon-box">
        <text>{{item.icon}}</text>
      </view>
      <text class="setting-label">{{item.label}}</text>
      <text class="setting-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 爱的寄语 -->
  <view class="love-note">
    <text class="love-icon">❤️</text>
    <text class="love-text">"最好的爱情，是你做饭来我洗碗"</text>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn" bindtap="logout">
    <text class="logout-icon">🚪</text>
    <text>退出登录</text>
  </view>
</view>
