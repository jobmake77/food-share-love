/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 40rpx 40rpx 160rpx;
}

/* ========== 个人资料卡片 ========== */
.profile-card {
  background: var(--gradient-warm);
  border-radius: var(--radius-lg);
  padding: 48rpx;
  box-shadow: var(--shadow-warm);
  margin-bottom: 32rpx;
  animation: fadeInUp 0.6s ease-out forwards;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--color-card);
  border: 4rpx solid var(--color-card);
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.profile-status {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 识别码 */
.id-code-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  margin-bottom: 32rpx;
}

.id-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}

.id-value {
  flex: 1;
  font-size: 28rpx;
  font-family: 'Courier New', monospace;
  font-weight: 700;
  color: #fff;
}

.copy-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.copy-btn:active {
  background: rgba(255, 255, 255, 0.2);
}

.copy-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 统计数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

.stat-item {
  text-align: center;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
  border-radius: var(--radius-md);
  padding: 16rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 伙伴绑定卡片 ========== */
.partner-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 32rpx;
  margin-bottom: 32rpx;
  animation: fadeInUp 0.6s ease-out 0.1s forwards;
  opacity: 0;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 28rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 已绑定状态 */
.partner-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.partner-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.partner-details {
  flex: 1;
}

.partner-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.partner-code {
  font-size: 18rpx;
  color: var(--color-text-hint);
  font-family: 'Courier New', monospace;
}

.unbind-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 18rpx;
  color: #ff4444;
  background: rgba(255, 68, 68, 0.1);
  border-radius: 48rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.unbind-btn:active {
  transform: scale(0.95);
}

/* 未绑定状态 */
.bind-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--color-secondary);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--color-text-hint);
  transition: all 0.3s ease;
}

.bind-btn:active {
  background: rgba(242, 125, 94, 0.1);
  color: var(--color-primary);
}

/* ========== 设置列表 ========== */
.settings-card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: 32rpx;
  animation: fadeInUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
}

.setting-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  transition: all 0.3s ease;
}

.setting-item:not(:last-child) {
  border-bottom: 2rpx solid var(--color-border);
}

.setting-item:active {
  background: rgba(0, 0, 0, 0.02);
}

.setting-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: var(--radius-sm);
  background: var(--color-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.setting-desc {
  font-size: 20rpx;
  color: var(--color-text-hint);
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

/* ========== 爱的寄语 ========== */
.love-note {
  background: var(--gradient-soft);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  text-align: center;
  margin-bottom: 32rpx;
  animation: fadeInUp 0.6s ease-out 0.3s forwards;
  opacity: 0;
}

.love-icon {
  font-size: 40rpx;
  margin-bottom: 16rpx;
  animation: pulseHeart 1.5s ease-in-out infinite;
}

.love-text {
  font-size: 20rpx;
  color: var(--color-text-hint);
  line-height: 1.6;
}

/* ========== 退出登录 ========== */
.logout-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  color: #ff4444;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  animation: fadeInUp 0.6s ease-out 0.4s forwards;
  opacity: 0;
}

.logout-btn:active {
  background: rgba(255, 68, 68, 0.05);
}

.logout-icon {
  font-size: 28rpx;
}
