/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 测试模式切换按钮 */
.test-mode-switch {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  z-index: 100;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 16rpx 24rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.switch-icon {
  font-size: 28rpx;
}

.switch-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  padding: 48rpx 32rpx 40rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  border: 4rpx solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.code-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
}

.code-value {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  font-family: monospace;
}

.copy-btn {
  background: rgba(255,255,255,0.25);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.partner-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 20rpx 24rpx 0;
}

.partner-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  flex-shrink: 0;
}

.partner-info {
  flex: 1;
}

.partner-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.partner-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.unbind-btn {
  font-size: 24rpx;
  color: var(--color-text-hint);
  padding: 8rpx 16rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
}

.bind-section {
  margin: 20rpx 24rpx 0;
}

.bind-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.bind-input-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.bind-input {
  flex: 1;
  height: 76rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.bind-submit-btn {
  background: linear-gradient(135deg, #FF6B6B, #FF8C42);
  color: #fff;
  font-size: 26rpx;
  padding: 0 28rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 12rpx;
  border: none;
  white-space: nowrap;
}

.bind-submit-btn::after {
  border: none;
}

.dev-test-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
}

.dev-divider {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.dev-divider::before,
.dev-divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.dev-divider-text {
  padding: 0 16rpx;
  font-size: 22rpx;
  color: var(--color-text-hint);
}

.dev-hint {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-hint);
  text-align: center;
  margin-top: 12rpx;
  line-height: 1.6;
}

.settings-list {
  margin: 20rpx 24rpx 0;
  padding: 0;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  gap: 16rpx;
}

/* 按钮样式的设置项 */
.setting-btn {
  width: 100%;
  background: transparent;
  border: none;
  text-align: left;
  padding: 28rpx 24rpx;
  margin: 0;
  line-height: normal;
}

.setting-btn::after {
  border: none;
}

.setting-icon {
  font-size: 36rpx;
  width: 48rpx;
}

.setting-label {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.setting-arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
}

.setting-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 24rpx;
}

.logout-btn {
  margin: 32rpx 24rpx 0;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--color-card);
  color: #FF3B30;
  font-size: 30rpx;
  border-radius: var(--radius-card);
}

/* 绑定请求列表 */
.bind-requests {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.requests-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.request-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.request-item:last-child {
  margin-bottom: 0;
}

.request-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--color-border);
  flex-shrink: 0;
}

.request-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.request-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.request-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.request-actions {
  display: flex;
  gap: 16rpx;
}

.request-btn {
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.request-btn.reject {
  background: var(--color-bg);
  color: var(--color-text-secondary);
  border: 2rpx solid var(--color-border);
}

.request-btn.accept {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  color: #fff;
}
