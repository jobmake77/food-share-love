/* subpages/category-manage/category-manage.wxss */
.container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

/* ========== 页面标题 ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: var(--gradient-warm);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-warm);
}

.add-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.add-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

/* ========== 分类列表 ========== */
.category-list {
  flex: 1;
  margin-bottom: 120rpx;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  animation: fadeInUp 0.6s ease-out forwards;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-md);
  background: var(--color-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.category-info {
  flex: 1;
  min-width: 0;
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.category-meta {
  font-size: 20rpx;
  color: var(--color-text-hint);
}

.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  font-size: 20rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn.edit {
  background: var(--color-secondary);
  color: var(--color-text-primary);
}

.action-btn.delete {
  background: rgba(255, 68, 68, 0.1);
  color: #ff4444;
}

.action-btn:active {
  transform: scale(0.95);
}

/* ========== 空状态 ========== */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 20rpx;
  color: var(--color-text-hint);
  display: block;
}

/* ========== 底部操作按钮 ========== */
.bottom-actions {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  gap: 16rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--color-border);
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 32rpx;
}

.action-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ========== 对话框 ========== */
.dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.dialog-content {
  width: 640rpx;
  max-height: 80vh;
  background: var(--color-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  animation: slideUp 0.3s ease;
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.dialog-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text-hint);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.dialog-close:active {
  background: var(--color-secondary);
}

.dialog-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: var(--color-bg);
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-input:focus {
  border-color: var(--color-primary);
}

/* ========== Emoji 选择器 ========== */
.emoji-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.emoji-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: var(--radius-md);
  background: var(--color-bg);
  transition: all 0.3s ease;
}

.emoji-item.active {
  background: var(--gradient-warm);
  transform: scale(1.1);
  box-shadow: var(--shadow-warm);
}

.emoji-item:active {
  transform: scale(0.9);
}

/* ========== 对话框底部 ========== */
.dialog-footer {
  display: flex;
  gap: 16rpx;
  padding: 32rpx;
  border-top: 2rpx solid var(--color-border);
}

.dialog-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
}

.dialog-btn.cancel {
  background: var(--color-secondary);
  color: var(--color-text-primary);
}

.dialog-btn.confirm {
  background: var(--gradient-warm);
  color: #fff;
  box-shadow: var(--shadow-warm);
}

.dialog-btn:active {
  transform: scale(0.95);
}

/* ========== 动画 ========== */
@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(100rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
