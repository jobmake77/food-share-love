.dish-list-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
  background: var(--color-bg);
}

.header .title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: var(--gradient-warm);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: var(--shadow-lg);
}

.add-btn .icon {
  font-size: 30rpx;
  font-weight: 700;
}

.search-box {
  padding: 0 30rpx 16rpx;
  background: var(--color-bg);
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 28rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-xl);
  font-size: 28rpx;
  color: var(--color-text-primary);
  box-sizing: border-box;
}

.category-tabs {
  white-space: nowrap;
  padding: 10rpx 30rpx 20rpx;
  background: var(--color-bg);
}

.category-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: var(--color-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-xl);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.category-tab.active {
  background: var(--gradient-warm);
  color: #fff;
  border-color: transparent;
  box-shadow: var(--shadow-md);
}

.category-icon {
  margin-right: 8rpx;
}

.dish-list {
  padding: 0 30rpx 20rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.dish-main {
  flex: 1;
  display: flex;
  gap: 20rpx;
  align-items: center;
  min-width: 0;
}

.dish-emoji {
  font-size: 58rpx;
  line-height: 1;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.dish-desc {
  font-size: 22rpx;
  color: var(--color-text-hint);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-category {
  font-size: 22rpx;
  color: var(--color-primary);
}

.dish-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-left: 16rpx;
}

.action-btn {
  padding: 10rpx 18rpx;
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
}

.action-btn.edit {
  background: var(--color-secondary);
  color: var(--color-text-primary);
}

.action-btn.delete {
  background: rgba(255, 68, 68, 0.1);
  color: #ff4444;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 110rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
  margin-bottom: 28rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: var(--gradient-warm);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: var(--shadow-md);
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx;
  font-size: 28rpx;
  color: var(--color-text-hint);
}
