/* subpages/edit-dish/edit-dish.wxss */
.edit-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 24rpx 24rpx 40rpx;
}

.image-upload {
  position: relative;
  height: 400rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.dish-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.upload-icon {
  font-size: 80rpx;
}

.upload-text {
  font-size: 26rpx;
  color: var(--color-text-hint);
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.4);
  padding: 16rpx;
  text-align: center;
}

.change-photo {
  color: #fff;
  font-size: 26rpx;
}

.form-card {
  margin-top: 20rpx;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
  padding: 0 24rpx;
}

.form-item {
  padding: 20rpx 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  height: 76rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  background: #fff;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  background: #fff;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.6;
}

.form-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 0 -24rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: var(--color-text-primary);
  height: 76rpx;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  background: #fff;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--color-text-hint);
}

.action-btns {
  margin-top: 32rpx;
}

.btn-danger {
  background: #FFF0F0;
  color: #FF3B30;
  border-radius: var(--radius-btn);
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  border: none;
  width: 100%;
  margin-top: 16rpx;
}

.btn-danger::after {
  border: none;
}

/* Emoji 选择器样式 */
.emoji-preview {
  display: flex;
  align-items: center;
}

.emoji-text {
  font-size: 48rpx;
  line-height: 1;
}

.emoji-hint {
  margin-left: 16rpx;
}

.emoji-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.emoji-modal-content {
  width: 100%;
  max-height: 70vh;
  background: var(--color-card);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  display: flex;
  flex-direction: column;
  border-top: 2rpx solid var(--color-border);
}

.emoji-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  border-bottom: 2rpx solid var(--color-border);
}

.emoji-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.emoji-modal-close {
  font-size: 28rpx;
  color: var(--color-text-hint);
  padding: 8rpx 16rpx;
}

.emoji-scroll {
  flex: 1;
  padding: 24rpx 32rpx;
}

.emoji-group {
  margin-bottom: 32rpx;
}

.emoji-group-title {
  font-size: 26rpx;
  color: var(--color-text-hint);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.emoji-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.emoji-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.emoji-item.active {
  background: var(--gradient-warm);
  transform: scale(1.1);
}
