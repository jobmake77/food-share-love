<!-- subpages/feedback/feedback.wxml -->
<view class="feedback-container">
  <view class="feedback-header">
    <text class="header-icon">💬</text>
    <text class="header-title">意见反馈</text>
    <text class="header-subtitle">您的建议是我们前进的动力</text>
  </view>

  <view class="feedback-form">
    <view class="form-section">
      <text class="form-label">反馈内容 <text class="required">*</text></text>
      <textarea
        class="feedback-textarea"
        placeholder="请详细描述您所遇到的问题或建议"
        value="{{content}}"
        bindinput="onContentInput"
        maxlength="500"
        show-confirm-bar="{{false}}"
        auto-height
      />
      <text class="char-count">{{content.length}}/500</text>
    </view>

    <button
      class="submit-btn"
      bindtap="submitFeedback"
      loading="{{submitting}}"
      disabled="{{submitting}}"
    >
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>
</view>
