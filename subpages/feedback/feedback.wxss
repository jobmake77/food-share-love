/* subpages/feedback/feedback.wxss */
.feedback-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding: 40rpx;
}

.feedback-header {
  background: var(--gradient-warm);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 4rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.feedback-form {
  padding: 0;
}

.form-section {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.required {
  color: var(--color-primary);
}

.feedback-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text-primary);
  background: #fff;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-border);
  padding: 24rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-hint);
  margin-top: 12rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: var(--gradient-warm);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: var(--shadow-lg);
}

.submit-btn[disabled] {
  opacity: 0.6;
}
