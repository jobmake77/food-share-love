/* subpages/feedback/feedback.wxss */
.feedback-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, var(--color-bg) 400rpx);
}

.feedback-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  padding: 80rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.feedback-form {
  padding: 32rpx 24rpx;
}

.form-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.required {
  color: var(--color-primary);
}

.feedback-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
}

.feedback-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: var(--color-text);
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8C42 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.tips {
  background: rgba(255, 107, 107, 0.05);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.tips-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
}
