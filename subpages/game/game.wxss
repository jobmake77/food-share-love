/* subpages/game/game.wxss */
.game-container {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.game-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 12rpx;
}

.game-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-hint);
  text-align: center;
  margin-bottom: 60rpx;
}

.game-options {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.game-option {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: var(--shadow-card);
}

.option-icon {
  font-size: 64rpx;
}

.option-name {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  color: var(--color-text-primary);
}

.option-desc {
  font-size: 24rpx;
  color: var(--color-text-hint);
  display: block;
  margin-top: 4rpx;
}

/* 疯狂点点点 */
.tap-game {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #000;
  display: flex;
  flex-direction: column;
}

/* 固定倒计时显示区域 */
.tap-timer-fixed {
  position: fixed;
  top: 60rpx;
  left: 0;
  right: 0;
  z-index: 100;
  text-align: center;
  pointer-events: none;
  background: rgba(0, 0, 0, 0.5);
  padding: 20rpx;
  backdrop-filter: blur(10rpx);
}

.tap-timer-fixed .game-title {
  color: #fff;
  font-size: 32rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.tap-countdown {
  display: block;
  font-size: 120rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.8);
}

.game-timer {
  font-size: 80rpx;
  color: #FFD700;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.tap-battle-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.tap-zone {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: height 0.1s ease-out;
  position: relative;
}

.tap-zone-red {
  background: linear-gradient(180deg, #FF4757 0%, #FF6B7A 100%);
}

.tap-zone-blue {
  background: linear-gradient(180deg, #5F9EFF 0%, #3742FA 100%);
}

.tap-zone-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.tap-zone-blue .tap-zone-content {
  flex-direction: column-reverse;
}

.tap-player-name {
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.tap-score {
  font-size: 96rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
  line-height: 1;
}

.tap-start {
  position: absolute;
  bottom: 100rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 100;
}

.btn-large {
  padding: 32rpx 80rpx;
  font-size: 36rpx;
}

/* 骰子 */
.dice-game {
  width: 100%;
  text-align: center;
}

.dice-area {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin: 60rpx 0;
}

.player-dice {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.player-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.dice {
  width: 150rpx;
  height: 150rpx;
  background: linear-gradient(135deg, #FF6B6B, #FF8C42);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
}

.result-dice {
  background: linear-gradient(135deg, #52C41A, #73D13D);
  box-shadow: 0 8rpx 24rpx rgba(82, 196, 26, 0.4);
}

.dice-num {
  font-size: 72rpx;
  font-weight: 900;
}

@keyframes rolling {
  0% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(15deg) scale(1.1); }
  50% { transform: rotate(-15deg) scale(0.9); }
  75% { transform: rotate(10deg) scale(1.1); }
  100% { transform: rotate(0deg) scale(1); }
}

.rolling {
  animation: rolling 0.3s ease infinite;
}

.vs-text {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-text-hint);
}

.dice-action {
  margin-top: 60rpx;
  width: 100%;
}

/* 剪刀石头布 */
.rps-game {
  width: 100%;
  text-align: center;
}

.rps-options {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin: 40rpx 0;
}

.rps-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 24rpx 20rpx;
  width: 180rpx;
  box-shadow: var(--shadow-card);
  gap: 8rpx;
}

.rps-icon {
  font-size: 56rpx;
}

.rps-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.rps-battle {
  margin-top: 60rpx;
}

.rps-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.rps-player {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.rps-icon-lg {
  font-size: 120rpx;
}

.rps-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 结果 */
.result-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.result-animation {
  margin-bottom: 32rpx;
}

.result-emoji {
  font-size: 160rpx;
}

.result-text {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.result-sub {
  display: block;
  font-size: 30rpx;
  color: var(--color-text-hint);
  text-align: center;
  margin-bottom: 60rpx;
}

.result-btns {
  width: 100%;
}
