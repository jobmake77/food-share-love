/* subpages/import-menu/import-menu.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 32rpx;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
  display: block;
}

.input-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.json-input {
  width: 100%;
  min-height: 400rpx;
  max-height: 600rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #333;
  font-family: 'Courier New', monospace;
}

.char-count {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  text-align: right;
}

.tips {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
}

.tip-item:not(:last-child) {
  border-bottom: 1rpx solid #f0f0f0;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

.button-group {
  display: flex;
  gap: 24rpx;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-secondary {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}

.btn-secondary[disabled] {
  opacity: 0.4;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

.btn-primary[disabled] {
  opacity: 0.6;
}
