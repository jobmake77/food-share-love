<!--subpages/import-sample/import-sample.wxml-->
<view class="container">
  <view class="header">
    <text class="icon">📚</text>
    <text class="title">官方菜单</text>
    <text class="subtitle">选择口味包，一键导入到你的菜单管理</text>
  </view>

  <view class="pack-list">
    <view
      class="pack-item {{selectedPackId === item.id ? 'active' : ''}}"
      wx:for="{{menuPacks}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onSelectPack"
    >
      <view class="pack-top">
        <text class="pack-name">{{item.name}}</text>
        <text class="pack-badge">{{item.categories}}类 · {{item.dishes}}条</text>
      </view>
      <text class="pack-tagline">{{item.tagline}}</text>
    </view>
  </view>

  <view class="stats">
    <view class="stat-item">
      <text class="stat-number">{{stats.categories}}</text>
      <text class="stat-label">个分类</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.dishes}}</text>
      <text class="stat-label">道菜品</text>
    </view>
  </view>

  <view class="preview">
    <view class="preview-title">包含内容</view>
    <view class="preview-list">
      <view class="preview-item" wx:for="{{preview}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="tips">
    <text class="tips-icon">💡</text>
    <text class="tips-text">导入后可在菜单管理中继续编辑、增删或再导入其他口味</text>
  </view>

  <button
    class="import-btn"
    type="primary"
    bindtap="importSample"
    loading="{{importing}}"
    disabled="{{importing || clearing}}"
  >
    {{importing ? '导入中...' : '导入当前官方菜单'}}
  </button>

  <button
    class="clear-btn"
    type="warn"
    bindtap="clearAllData"
    loading="{{clearing}}"
    disabled="{{importing || clearing}}"
  >
    {{clearing ? '清空中...' : '清空所有数据'}}
  </button>
</view>
