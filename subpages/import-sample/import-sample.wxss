/* subpages/import-sample/import-sample.wxss */
.container {
  padding: 40rpx;
  min-height: 100vh;
  background: var(--color-bg);
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
}

.icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 12rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--color-text-hint);
  display: block;
}

.pack-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.pack-item {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  border: 2rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.pack-item.active {
  border-color: rgba(242, 125, 94, 0.35);
  box-shadow: 0 0 0 6rpx rgba(242, 125, 94, 0.08), var(--shadow-card);
}

.pack-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.pack-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 700;
}

.pack-badge {
  font-size: 22rpx;
  color: #fff;
  background: var(--gradient-warm);
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.pack-tagline {
  font-size: 24rpx;
  color: var(--color-text-hint);
  line-height: 1.6;
}

.stats {
  display: flex;
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--color-primary);
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
}

.stat-divider {
  width: 2rpx;
  background: var(--color-border);
  margin: 0 24rpx;
}

.preview {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.preview-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.preview-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-item {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  padding-left: 8rpx;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.tips-icon {
  font-size: 32rpx;
}

.tips-text {
  font-size: 26rpx;
  color: var(--color-text-hint);
}

.import-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--gradient-warm);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: var(--shadow-lg);
  margin-bottom: 24rpx;
}

.import-btn[disabled] {
  opacity: 0.6;
}

.clear-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--color-card);
  color: #ff4444;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: var(--shadow-card);
  border: 2rpx solid rgba(255, 68, 68, 0.3);
}

.clear-btn[disabled] {
  opacity: 0.6;
}
