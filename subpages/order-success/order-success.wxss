/* subpages/order-success/order-success.wxss */
.success-container {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

.success-top {
  background: linear-gradient(135deg, #FF6B6B, #FF8C42);
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.success-emoji {
  font-size: 80rpx;
}

.success-title {
  font-size: 48rpx;
  font-weight: 900;
  color: #fff;
  margin-bottom: 8rpx;
}

.success-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.order-summary {
  margin: 24rpx;
}

.summary-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
}

.summary-dishes {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.summary-dish {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.summary-dish-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.summary-dish-count {
  font-size: 26rpx;
  color: var(--color-text-hint);
}

.summary-note {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  gap: 12rpx;
}

.note-label {
  font-size: 24rpx;
  color: var(--color-text-hint);
  white-space: nowrap;
}

.note-content {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  flex: 1;
}

.action-btns {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}
